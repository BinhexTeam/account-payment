<odoo>
    <record id="view_payment_term_form" model="ir.ui.view">
        <field
            name="name"
        >account.payment.term.form.inherit.account_payment_term_partner_not_paydays</field>
        <field name="model">account.payment.term</field>
        <field
            name="inherit_id"
            ref="account_payment_term_extension.view_payment_term_form"
        />
        <field name="arch" type="xml">
            <xpath
                expr="//field[@name='line_ids']/tree//field[@name='payment_days']"
                position="attributes"
            >
                <attribute name="column_invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>
