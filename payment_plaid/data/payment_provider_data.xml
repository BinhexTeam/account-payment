<odoo>
    <!-- Proveedor Plaid Transferencia Manual -->
    <record id="payment_provider_plaid_manual" model="payment.provider">
        <field name="name">Plaid (Bank Transfer)</field>
        <field name="code">plaid_manual</field>
        <field name="fees_active">False</field>
        <field name="state">disabled</field>
        <field name="module_id" ref="base.module_payment_plaid" />
        <field name="company_id" ref="base.main_company" />
        <field name="inline_form_view_id" ref="payment_plaid.payment_form_plaid_manual" />
        <field name="payment_icon_ids" eval="False" />
        <field name="image_128"
               type="base64"
               file="payment_plaid/static/description/icon.png"/>
        <!-- Mensajes para el usuario -->
        <field name="pending_msg">We've registered your order. 
        Please transfer the amount to our bank account, and your order will be processed once payment is confirmed.
        </field>
        <field name="done_msg">We have received your payment by transfer. Thank you for your purchase!</field>
    </record>
</odoo>